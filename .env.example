# Template — copy to .env.local and fill in. NEVER put real secrets in this file.
# (.env.local is git-ignored; .env.example is committed.)

# ── Supabase ────────────────────────────────────────────────────────────────
# Project URL + browser key are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
# Use EITHER the legacy anon key OR the new publishable key (sb_publishable_…).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Service-role key is SERVER ONLY. Never prefix with NEXT_PUBLIC_.
# Use EITHER SUPABASE_SERVICE_ROLE_KEY OR the new secret key (sb_secret_…).
SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_SECRET_KEY=

# ── OpenAI ──────────────────────────────────────────────────────────────────
# Server only. Used for image generation/editing (gpt-image-1).
OPENAI_API_KEY=
# Optional override of the image model (defaults to gpt-image-1).
OPENAI_IMAGE_MODEL=gpt-image-1

# ── App secrets ─────────────────────────────────────────────────────────────
# Random string used to sign parent-session cookies + device tokens, salt PINs.
# Generate with:  openssl rand -hex 32
PARENT_PIN_SECRET=
