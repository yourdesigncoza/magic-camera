# ── Supabase ────────────────────────────────────────────────────────────────
# Project URL + anon key are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key is SERVER ONLY. Never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# ── OpenAI ──────────────────────────────────────────────────────────────────
# Server only. Used for image generation/editing (gpt-image-1).
OPENAI_API_KEY=
# Optional override of the image model (defaults to gpt-image-1).
OPENAI_IMAGE_MODEL=gpt-image-1

# ── App secrets ─────────────────────────────────────────────────────────────
# Random string used to sign parent-session cookies and salt PIN hashes.
# Generate with:  openssl rand -hex 32
PARENT_PIN_SECRET=
